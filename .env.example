# Django Secret Key - MUST be changed in production
# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-super-secret-key-change-in-production

# Debug Mode - MUST be False in production
DEBUG=True

# Allowed Hosts - Comma separated list
ALLOWED_HOSTS=127.0.0.1,localhost

# CSRF Trusted Origins - Full URLs with protocol
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Database URL (Optional - defaults to SQLite if not set)
# For PostgreSQL: postgres://user:password@host:port/dbname
# DATABASE_URL=postgres://user:password@localhost:5432/team_tracker

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
